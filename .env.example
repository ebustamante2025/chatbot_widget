# URL del API Backend (mismo puerto que chatbot_api_backend: PORT en .env del API, por defecto 3004).
# Debe coincidir con CRM_API_BASE_URL del asistente Streamlit (chatbot_Agente/.env).
VITE_API_URL=http://localhost:3004/api

# Página de preguntas frecuentes (al hacer clic en "Preguntas frecuentes" se redirige aquí).
# Si no se define: en modo desarrollo → http://localhost:3009, en Docker/producción → http://localhost:3008
# Producción: https://preguntasfrecuntes.hginet.com.co
# VITE_FAQ_URL=http://localhost:3008
# VITE_FAQ_URL=https://preguntasfrecuntes.hginet.com.co

# Prueba / IA360: por defecto chat integrado en el widget (misma conversación CRM /ia360-doc que Streamlit).
# Misma lógica de consulta: OpenAI + Notion en el API; mensajes en canal IA360_DOC.
# Solo pestaña Streamlit (chatbot_Agente): VITE_IA360_USE_WIDGET=false
# VITE_IA360_USE_WIDGET=false

# Si usa Streamlit: URL base ( ?servicio= & token= )
# VITE_AGENTE_URL=http://localhost:8501

# Webhook al seleccionar el servicio (registro)
# VITE_ISA_REGISTRO_WEBHOOK_URL=https://agentehgi.hginet.com.co/webhook/1986379d-...
# Webhook para mensajes del chat (input)
# VITE_ISA_AGENT_WEBHOOK_URL=https://agentehgi.hginet.com.co/webhook/72919732-...
