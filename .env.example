# URL del API Backend. En contenedor el backend está en el puerto 3001.
# Si obtienes 404 en /api/faq-acceso, verifica que este puerto sea el donde corre chatbot_api_backend.
VITE_API_URL=http://localhost:3001/api

# Página de preguntas frecuentes (al hacer clic en "Preguntas frecuentes" se redirige aquí).
# Si no se define: en modo desarrollo → http://localhost:3009, en Docker → valor del Dockerfile/docker-compose.
# Para Docker: se puede pasar VITE_FAQ_URL en el .env al hacer docker-compose build; por defecto la imagen usa https://preguntasfrecuntes.hginet.com.co
VITE_FAQ_URL=https://preguntasfrecuntes.hginet.com.co

# Webhook al seleccionar el servicio (registro)
# VITE_ISA_REGISTRO_WEBHOOK_URL=https://agentehgi.hginet.com.co/webhook/1986379d-...
# Webhook para mensajes del chat (input)
# VITE_ISA_AGENT_WEBHOOK_URL=https://agentehgi.hginet.com.co/webhook/72919732-...
